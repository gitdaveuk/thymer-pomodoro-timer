class Plugin extends AppPlugin {

    onLoad() {
        this.timerState = {
            isRunning: false,
            isPaused: false,
            currentSession: 'work',
            timeRemaining: 0,
            totalTime: 0,
            sessionsCompleted: 0,
        };

        this.settings = {
            workDuration: 25,
            shortBreakDuration: 5,
            longBreakDuration: 15,
            sessionsBeforeLongBreak: 4,
            autoStartBreaks: false,
            autoStartWork: false,
        };

        this.timerInterval = null;

        this.statusBarItem = this.ui.addStatusBarItem({
            icon: 'clock',
            label: this.formatTime(this.settings.workDuration * 60),
            tooltip: 'Click to start Pomodoro',
            onClick: () => this.handleStatusBarClick()
        });

        this.commands = [
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Start",
                icon: "player-play",
                onSelected: () => this.startTimer()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Pause",
                icon: "player-pause",
                onSelected: () => this.pauseTimer()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Stop",
                icon: "player-stop",
                onSelected: () => this.stopTimer()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Skip to Break",
                icon: "player-skip-forward",
                onSelected: () => this.skipToBreak()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Status",
                icon: "clock",
                onSelected: () => this.showStatus()
            }),
            this.ui.addCommandPaletteCommand({
                label: "Pomodoro — Settings",
                icon: "settings",
                onSelected: () => this.showSettings()
            }),
        ];
    }

    onUnload() {
        this.stopInterval();
        this.statusBarItem?.remove();
        this.commands?.forEach(c => c.remove());
    }

    // ─── Timer control ───────────────────────────────────────────────

    startTimer() {
        if (this.timerState.isRunning && !this.timerState.isPaused) {
            this.toast("Already running", `${this.formatTime(this.timerState.timeRemaining)} remaining`);
            return;
        }

        if (this.timerState.isPaused) {
            this.timerState.isPaused = false;
            this.toast("▶ Resumed", `${this.formatTime(this.timerState.timeRemaining)} remaining`);
        } else {
            this.timerState.currentSession = 'work';
            this.timerState.timeRemaining = this.settings.workDuration * 60;
            this.timerState.totalTime = this.timerState.timeRemaining;
            this.timerState.isRunning = true;
            this.toast("▶ Pomodoro started", `${this.settings.workDuration} min — focus time!`);
        }

        this.startInterval();
        this.updateStatusBar();
    }

    pauseTimer() {
        if (!this.timerState.isRunning) {
            this.toast("No timer running", "Start a timer first");
            return;
        }
        if (this.timerState.isPaused) {
            this.toast("Already paused", "Use Start to resume");
            return;
        }

        this.timerState.isPaused = true;
        this.stopInterval();
        this.updateStatusBar();
        this.toast("⏸ Paused", `${this.formatTime(this.timerState.timeRemaining)} remaining`);
    }

    stopTimer() {
        if (!this.timerState.isRunning) {
            this.toast("No timer running", "Start a timer first");
            return;
        }

        this.stopInterval();
        this.timerState.isRunning = false;
        this.timerState.isPaused = false;
        this.timerState.timeRemaining = 0;
        this.updateStatusBar();
        this.toast("■ Stopped", `${this.timerState.sessionsCompleted} Pomodoros completed`);
    }

    skipToBreak() {
        if (!this.timerState.isRunning) {
            this.toast("No timer running", "Start a timer first");
            return;
        }
        if (this.timerState.currentSession !== 'work') {
            this.toast("Already on a break", "");
            return;
        }

        this.timerState.sessionsCompleted++;
        this.startBreak();
    }

    // ─── Break ───────────────────────────────────────────────────────

    startBreak() {
        const isLong = this.timerState.sessionsCompleted % this.settings.sessionsBeforeLongBreak === 0;
        this.timerState.currentSession = isLong ? 'longBreak' : 'shortBreak';
        this.timerState.timeRemaining = (isLong ? this.settings.longBreakDuration : this.settings.shortBreakDuration) * 60;
        this.timerState.totalTime = this.timerState.timeRemaining;
        this.timerState.isRunning = true;
        this.timerState.isPaused = false;

        const label = isLong ? 'Long break' : 'Short break';
        const mins = isLong ? this.settings.longBreakDuration : this.settings.shortBreakDuration;
        this.toast(`${isLong ? '🌴' : '☕'} ${label}`, `${mins} minutes — relax!`);

        this.startInterval();
        this.updateStatusBar();
    }

    // ─── Interval ────────────────────────────────────────────────────

    startInterval() {
        this.stopInterval();
        this.timerInterval = setInterval(() => this.tick(), 1000);
    }

    stopInterval() {
        if (this.timerInterval) {
            clearInterval(this.timerInterval);
            this.timerInterval = null;
        }
    }

    tick() {
        this.timerState.timeRemaining--;
        this.updateStatusBar();

        if (this.timerState.timeRemaining === 60) {
            this.toast("⏰ 1 minute remaining",
                this.timerState.currentSession === 'work' ? "Wrap up your task" : "Break almost over");
        }

        if (this.timerState.timeRemaining <= 0) {
            this.sessionComplete();
        }
    }

    sessionComplete() {
        this.stopInterval();

        if (this.timerState.currentSession === 'work') {
            this.timerState.sessionsCompleted++;
            this.toast("🎉 Work session complete!", `${this.timerState.sessionsCompleted} Pomodoros today`, 5000);

            if (this.settings.autoStartBreaks) {
                setTimeout(() => this.startBreak(), 2000);
            } else {
                this.timerState.isRunning = false;
                this.updateStatusBar();
            }
        } else {
            this.toast("Break complete!", "Ready to get back to work?", 5000);

            if (this.settings.autoStartWork) {
                setTimeout(() => this.startTimer(), 2000);
            } else {
                this.timerState.isRunning = false;
                this.updateStatusBar();
            }
        }
    }

    // ─── Status bar ──────────────────────────────────────────────────

    handleStatusBarClick() {
        if (!this.timerState.isRunning || this.timerState.isPaused) {
            this.startTimer();
        } else {
            this.pauseTimer();
        }
    }

    updateStatusBar() {
        if (!this.timerState.isRunning) {
            this.statusBarItem.setIcon('clock');
            this.statusBarItem.setLabel(this.formatTime(this.settings.workDuration * 60));
            this.statusBarItem.setTooltip(`Click to start — ${this.timerState.sessionsCompleted} sessions today`);
            return;
        }

        const timeStr = this.formatTime(this.timerState.timeRemaining);
        const paused = this.timerState.isPaused;

        let icon, prefix, sessionName;
        switch (this.timerState.currentSession) {
            case 'shortBreak':
                icon = 'coffee'; prefix = '☕ '; sessionName = 'Short break'; break;
            case 'longBreak':
                icon = 'beach'; prefix = '🌴 '; sessionName = 'Long break'; break;
            default:
                icon = paused ? 'player-pause' : 'clock';
                prefix = ''; sessionName = 'Work';
        }

        this.statusBarItem.setIcon(icon);
        this.statusBarItem.setLabel(`${prefix}${timeStr}${paused ? ' (paused)' : ''}`);
        this.statusBarItem.setTooltip(
            `${sessionName} — ${timeStr} remaining\n` +
            `${paused ? 'Click to resume' : 'Click to pause'}\n` +
            `Sessions today: ${this.timerState.sessionsCompleted}`
        );
    }

    // ─── Info ─────────────────────────────────────────────────────────

    showStatus() {
        if (!this.timerState.isRunning) {
            this.toast("No timer running", `${this.timerState.sessionsCompleted} sessions completed today`);
            return;
        }

        const session = this.timerState.currentSession === 'work' ? 'Work' :
                        this.timerState.currentSession === 'shortBreak' ? 'Short break' : 'Long break';
        const pct = Math.round((1 - this.timerState.timeRemaining / this.timerState.totalTime) * 100);

        this.toast(
            `${session}${this.timerState.isPaused ? ' (paused)' : ''}`,
            `${this.formatTime(this.timerState.timeRemaining)} remaining (${pct}% done)\n${this.timerState.sessionsCompleted} sessions today`,
            4000
        );
    }

    showSettings() {
        const el = this.statusBarItem.getElement();
        if (!el) return;

        this.ui.createDropdown({
            attachedTo: el,
            inputPlaceholder: 'Settings...',
            width: 260,
            options: [
                {
                    label: `Work: ${this.settings.workDuration} min`,
                    icon: 'clock',
                    onSelected: () => this.cycleSetting('workDuration', [15, 20, 25, 30, 45, 50, 60])
                },
                {
                    label: `Short break: ${this.settings.shortBreakDuration} min`,
                    icon: 'coffee',
                    onSelected: () => this.cycleSetting('shortBreakDuration', [3, 5, 10])
                },
                {
                    label: `Long break: ${this.settings.longBreakDuration} min`,
                    icon: 'beach',
                    onSelected: () => this.cycleSetting('longBreakDuration', [10, 15, 20, 30])
                },
                {
                    label: `Sessions before long break: ${this.settings.sessionsBeforeLongBreak}`,
                    icon: 'list',
                    onSelected: () => this.cycleSetting('sessionsBeforeLongBreak', [2, 3, 4, 5, 6])
                },
                {
                    label: `Auto-start breaks: ${this.settings.autoStartBreaks ? 'On' : 'Off'}`,
                    icon: 'player-play',
                    onSelected: () => { this.settings.autoStartBreaks = !this.settings.autoStartBreaks; this.showSettings(); }
                },
                {
                    label: `Auto-start work: ${this.settings.autoStartWork ? 'On' : 'Off'}`,
                    icon: 'player-play',
                    onSelected: () => { this.settings.autoStartWork = !this.settings.autoStartWork; this.showSettings(); }
                },
            ]
        });
    }

    cycleSetting(key, values) {
        const current = this.settings[key];
        const idx = values.indexOf(current);
        this.settings[key] = values[(idx + 1) % values.length];
        this.toast(`Updated`, `${key.replace(/([A-Z])/g, ' $1').toLowerCase()}: ${this.settings[key]}`);
        // Reset status bar label if timer not running
        if (!this.timerState.isRunning) this.updateStatusBar();
    }

    // ─── Helpers ─────────────────────────────────────────────────────

    formatTime(seconds) {
        const m = Math.floor(seconds / 60);
        const s = seconds % 60;
        return `${m}:${s.toString().padStart(2, '0')}`;
    }

    toast(title, message, autoDestroyTime = 2500) {
        this.ui.addToaster({ title, message, dismissible: true, autoDestroyTime });
    }
}
